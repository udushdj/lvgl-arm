<!--pages/index/index.wxml-->
<view class="container">
  <!-- 顶部标题栏 -->
  <view class="header bg-gradient-primary">
    <view class="header-left">
      <text class="header-title">🏥 内科门诊</text>
    </view>
    <view class="header-badge">诊室 3</view>
  </view>

  <!-- 当前就诊患者卡片 -->
  <view class="current-patient-card card" wx:if="{{currentPatient}}">
    <view class="accent-bar"></view>
    <view class="badge badge-primary mb-sm">正在就诊</view>
    <text class="patient-name">{{currentPatient.name}}</text>
    <text class="patient-id">{{currentPatient.Patient_ID}}</text>
    <text class="patient-extra">{{currentPatient.age}}岁 | {{currentPatient.ID_number}}</text>
  </view>

  <view class="card empty-card" wx:else>
    <view class="empty-state">
      <view class="icon">📋</view>
      <text>暂无当前患者</text>
    </view>
  </view>

  <!-- 统计数据行 -->
  <view class="stats-row flex gap-md mt-lg">
    <view class="stat-card card-compact flex-1">
      <text class="stat-label text-secondary">等待人数</text>
      <text class="stat-value text-blue text-bold">{{waitingCount}}</text>
    </view>
    <view class="stat-card card-compact flex-1">
      <text class="stat-label text-secondary">下一位</text>
      <text class="stat-value text-blue text-bold">{{nextPatient || '—'}}</text>
    </view>
    <view class="stat-card card-compact flex-1">
      <text class="stat-label text-secondary">总人数</text>
      <text class="stat-value text-blue text-bold">{{totalCount}}</text>
    </view>
  </view>

  <!-- 候诊队列 -->
  <view class="queue-section mt-lg">
    <view class="section-header flex-between mb-md">
      <text class="section-title text-bold">候诊队列</text>
      <text class="text-secondary">></text>
    </view>

    <view class="queue-list card">
      <block wx:if="{{waitingList.length > 0}}">
        <view 
          class="queue-item" 
          wx:for="{{waitingList}}" 
          wx:key="Patient_ID"
          wx:if="{{index < 4}}"
        >
          <view class="queue-order">{{index + 2}}</view>
          <view class="queue-item-info flex-1">
            <text class="queue-name text-bold">{{item.Patient_ID}}: {{item.name}}</text>
            <text class="queue-age text-secondary">{{item.age}}岁</text>
          </view>
          <view class="divider" wx:if="{{index < 3 && index < waitingList.length - 1}}"></view>
        </view>
      </block>

      <view wx:else class="empty-state">
        <text>暂无候诊患者</text>
      </view>
    </view>
  </view>

  <!-- 底部操作按钮 2x2 -->
  <view class="bottom-actions">
    <view class="actions-grid">
      <button class="btn btn-primary" bindtap="onCallNext">
        📢 <text>叫下一位</text>
      </button>
      <button class="btn btn-primary" bindtap="goQueue">
        📋 <text>管理队列</text>
      </button>
      <button class="btn btn-primary" bindtap="goStats">
        📊 <text>查看统计</text>
      </button>
      <button class="btn btn-primary" bindtap="goAdd">
        ＋ <text>添加患者</text>
      </button>
    </view>
  </view>
</view>
