/**
 * 全局样式 — Verdant Teal 设计系统
 */

page {
  /* ── 色彩系统 ── */
  --color-primary: #0f766e;
  --color-primary-light: #5eead4;
  --color-primary-dark: #115e59;
  --color-gradient-start: #115e59;
  --color-gradient-end: #14b8a6;

  --color-success: #059669;
  --color-warning: #d97706;
  --color-danger: #dc2626;

  --color-bg: #f3f4f3;
  --color-surface: #ffffff;
  --color-border: #e0e3e1;

  --color-text-primary: #171a19;
  --color-text-secondary: #6b7170;
  --color-text-tertiary: #9da3a0;

  /* ── 间距 ── */
  --space-xs: 8rpx;
  --space-sm: 12rpx;
  --space-md: 16rpx;
  --space-lg: 24rpx;
  --space-xl: 32rpx;
  --space-2xl: 40rpx;

  /* ── 圆角 ── */
  --radius-sm: 8rpx;
  --radius-md: 14rpx;
  --radius-lg: 20rpx;
  --radius-xl: 24rpx;
  --radius-pill: 999rpx;

  /* ── 阴影 ── */
  --shadow-sm: 0 2rpx 8rpx rgba(15, 118, 110, 0.04);
  --shadow-md: 0 4rpx 16rpx rgba(15, 118, 110, 0.07);
  --shadow-lg: 0 8rpx 32rpx rgba(15, 118, 110, 0.10);
  --shadow-primary: 0 6rpx 20rpx rgba(15, 118, 110, 0.20);

  /* ── 字体 ── */
  --font-size-xs: 22rpx;
  --font-size-sm: 26rpx;
  --font-size-base: 30rpx;
  --font-size-lg: 34rpx;
  --font-size-xl: 38rpx;
  --font-size-2xl: 44rpx;
  --font-size-3xl: 56rpx;
  --font-size-display: 96rpx;

  background-color: var(--color-bg);
  color: var(--color-text-primary);
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Helvetica Neue", sans-serif;
  font-size: var(--font-size-base);
  line-height: 1.6;
  -webkit-font-smoothing: antialiased;
}

/* ── 容器与卡片 ── */

.container {
  padding: var(--space-md) var(--space-lg);
  min-height: 100vh;
}

.card {
  background: var(--color-surface);
  border-radius: var(--radius-lg);
  padding: var(--space-lg);
  box-shadow: var(--shadow-sm);
  border: 1rpx solid transparent;
}

.card-compact {
  padding: var(--space-md);
}

/* ── 按钮 ── */

.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: var(--space-sm);
  height: 88rpx;
  padding: 0 var(--space-lg);
  border-radius: 44rpx;
  font-size: var(--font-size-base);
  font-weight: 600;
  transition: all 0.2s ease;
  border: none;
  letter-spacing: 0.02em;
}

.btn-primary {
  background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-dark) 100%);
  color: #fff;
  box-shadow: var(--shadow-primary);
}

.btn-primary:active {
  transform: scale(0.97);
  box-shadow: 0 2rpx 8rpx rgba(15, 118, 110, 0.15);
}

.btn-primary::after {
  border: none;
}

.btn-outline {
  background: transparent;
  border: 2rpx solid currentColor;
  border-radius: var(--radius-md);
}

.btn-outline::after {
  border: none;
}

.btn-outline.btn-primary {
  color: var(--color-primary);
}

.btn-outline.btn-success {
  color: var(--color-success);
}

.btn-outline.btn-warning {
  color: var(--color-warning);
}

.btn-outline:active {
  background: rgba(15, 118, 110, 0.06);
}

/* ── 徽章 ── */

.badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 4rpx 16rpx;
  border-radius: var(--radius-pill);
  font-size: var(--font-size-xs);
  font-weight: 600;
  white-space: nowrap;
  letter-spacing: 0.03em;
}

.badge-primary {
  background: #ccfbf1;
  color: #0f766e;
}

.badge-gray {
  background: #f3f4f3;
  color: var(--color-text-secondary);
}

.badge-blue {
  background: #ccfbf1;
  color: #0f766e;
}

/* ── 分割线 ── */

.divider {
  height: 1rpx;
  background: var(--color-border);
  margin: var(--space-md) 0;
}

/* ── 图标 ── */

.icon {
  width: 48rpx;
  height: 48rpx;
  display: inline-block;
}

.icon-sm  { width: 40rpx; height: 40rpx; }
.icon-lg  { width: 56rpx; height: 56rpx; }

/* ── 文本工具类 ── */

.text-primary   { color: var(--color-text-primary); }
.text-secondary { color: var(--color-text-secondary); }
.text-tertiary  { color: var(--color-text-tertiary); }
.text-teal      { color: var(--color-primary); }
.text-success   { color: var(--color-success); }
.text-warning   { color: var(--color-warning); }
.text-danger    { color: var(--color-danger); }
.text-bold      { font-weight: 600; }
.text-center    { text-align: center; }

/* 向后兼容 */
.text-blue { color: var(--color-primary); }

/* ── 布局工具类 ── */

.flex          { display: flex; }
.flex-center   { display: flex; align-items: center; justify-content: center; }
.flex-between  { display: flex; align-items: center; justify-content: space-between; }
.flex-col      { display: flex; flex-direction: column; }
.flex-1        { flex: 1; }

.gap-xs  { gap: var(--space-xs);  }
.gap-sm  { gap: var(--space-sm);  }
.gap-md  { gap: var(--space-md);  }
.gap-lg  { gap: var(--space-lg);  }

/* ── 间距工具类 ── */

.mt-xs  { margin-top: var(--space-xs);  }
.mt-sm  { margin-top: var(--space-sm);  }
.mt-md  { margin-top: var(--space-md);  }
.mt-lg  { margin-top: var(--space-lg);  }
.mt-xl  { margin-top: var(--space-xl);  }

.mb-xs  { margin-bottom: var(--space-xs);  }
.mb-sm  { margin-bottom: var(--space-sm);  }
.mb-md  { margin-bottom: var(--space-md);  }
.mb-lg  { margin-bottom: var(--space-lg);  }
.mb-xl  { margin-bottom: var(--space-xl);  }

/* ── 渐变背景 ── */

.bg-gradient-primary {
  background: linear-gradient(135deg, var(--color-gradient-start) 0%, var(--color-gradient-end) 100%);
}

/* ── 空状态 ── */

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: var(--space-xl);
  color: var(--color-text-tertiary);
}

.empty-state .icon {
  width: 128rpx;
  height: 128rpx;
  margin-bottom: var(--space-md);
  opacity: 0.25;
}

.empty-state text {
  font-size: var(--font-size-lg);
}

/* ── 骨架屏 ── */

.skeleton {
  background: linear-gradient(90deg, #e8eae8 25%, #dcdfdd 50%, #e8eae8 75%);
  background-size: 200% 100%;
  animation: skeleton-loading 1.5s ease-in-out infinite;
  border-radius: var(--radius-sm);
}

@keyframes skeleton-loading {
  0%   { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}
